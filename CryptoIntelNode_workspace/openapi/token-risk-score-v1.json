{
  "openapi": "3.1.0",
  "info": {
    "title": "Crypto Intel Node Token Risk Score API",
    "version": "1.0.0"
  },
  "x-analysis-networks": [
    "eip155:1",
    "eip155:56",
    "eip155:8453",
    "eip155:42161",
    "eip155:196"
  ],
  "x-payment": {
    "protocol": "official-okx-x402",
    "passthrough402": true
  },
  "paths": {
    "/v1/token-risk-score": {
      "get": {
        "operationId": "getTokenRiskScore",
        "summary": "获取 EVM 代币风险评分",
        "parameters": [
          {
            "name": "network",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["eip155:1", "eip155:56", "eip155:8453", "eip155:42161", "eip155:196"]
            }
          },
          {
            "name": "address",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^0x(?!0{40}$)[0-9a-fA-F]{40}$"
            }
          },
          {
            "name": "locale",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["zh-CN", "en-US"],
              "default": "zh-CN"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "评分成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RiskScoreResponse" }
              }
            }
          },
          "400": {
            "description": "缺少必填参数",
            "x-error-codes": ["missing_parameter"],
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/Problem" }
              }
            }
          },
          "402": {
            "description": "官方 OKX x402 支付挑战原样透传",
            "x-okx-x402-passthrough": true,
            "headers": {
              "WWW-Authenticate": { "schema": { "type": "string" } },
              "PAYMENT-REQUIRED": { "schema": { "type": "string" } }
            }
          },
          "404": {
            "description": "已确认资产不存在",
            "x-error-codes": ["asset_not_found"],
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/Problem" }
              }
            }
          },
          "422": {
            "description": "参数语义非法",
            "x-error-codes": ["invalid_address", "unsupported_network", "invalid_locale"],
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/Problem" }
              }
            }
          },
          "503": {
            "description": "证据不足或上游暂时失败",
            "x-error-codes": ["evidence_unavailable", "upstream_unavailable"],
            "content": {
              "application/problem+json": {
                "schema": { "$ref": "#/components/schemas/Problem" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RiskScoreResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schemaVersion", "scoreVersion", "requestId", "asset", "assessment", "dimensions", "freshness", "evidence", "missing", "conflicts", "disclaimer"],
        "properties": {
          "schemaVersion": { "const": "1.0" },
          "scoreVersion": { "const": "risk-v1.0.0" },
          "requestId": { "type": "string", "minLength": 1 },
          "asset": { "$ref": "#/components/schemas/Asset" },
          "assessment": { "$ref": "#/components/schemas/Assessment" },
          "dimensions": {
            "type": "object",
            "additionalProperties": false,
            "required": ["security", "liquidity", "concentration"],
            "properties": {
              "security": { "$ref": "#/components/schemas/Dimension" },
              "liquidity": { "$ref": "#/components/schemas/Dimension" },
              "concentration": { "$ref": "#/components/schemas/Dimension" }
            }
          },
          "freshness": { "$ref": "#/components/schemas/Freshness" },
          "evidence": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Evidence" }
          },
          "missing": { "type": "array", "items": { "type": "string" } },
          "conflicts": { "type": "array", "items": { "type": "string" } },
          "disclaimer": { "type": "string", "minLength": 1 }
        }
      },
      "Asset": {
        "type": "object",
        "additionalProperties": false,
        "required": ["network", "address"],
        "properties": {
          "network": { "type": "string", "enum": ["eip155:1", "eip155:56", "eip155:8453", "eip155:42161", "eip155:196"] },
          "address": { "type": "string", "pattern": "^0x(?!0{40}$)[0-9a-fA-F]{40}$" }
        }
      },
      "Assessment": {
        "type": "object",
        "additionalProperties": false,
        "required": ["score", "level", "confidence"],
        "properties": {
          "score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      },
      "Dimension": {
        "type": "object",
        "additionalProperties": false,
        "required": ["score", "status"],
        "properties": {
          "score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "status": { "type": "string", "enum": ["fresh", "stale", "conflicted"] }
        }
      },
      "Freshness": {
        "type": "object",
        "additionalProperties": false,
        "required": ["observedAt", "expiresAt", "stale"],
        "properties": {
          "observedAt": { "type": "string", "format": "date-time" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "stale": { "type": "boolean" }
        }
      },
      "Evidence": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "source", "summary", "observedAt"],
        "properties": {
          "dimension": { "type": "string", "enum": ["security", "liquidity", "concentration"] },
          "source": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "observedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Problem": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "title", "status", "code", "detail", "requestId", "retryable", "score"],
        "properties": {
          "type": { "type": "string", "format": "uri" },
          "title": { "type": "string", "minLength": 1 },
          "status": { "type": "integer", "enum": [400, 404, 422, 503] },
          "code": { "type": "string", "enum": ["missing_parameter", "invalid_address", "unsupported_network", "invalid_locale", "asset_not_found", "evidence_unavailable", "upstream_unavailable"] },
          "detail": { "type": "string", "minLength": 1 },
          "requestId": { "type": "string", "minLength": 1 },
          "retryable": { "type": "boolean" },
          "score": { "type": "null" }
        }
      }
    }
  }
}
